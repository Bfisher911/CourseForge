VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# OpenAI — SECRET. Do NOT prefix with VITE_ (that would ship the key to the browser).
# Use server-side only (Netlify Function / Supabase Edge Function). For production,
# set this in the Netlify dashboard, not in committed files.
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: default chat model used by netlify/functions/openai.ts (falls back to gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini
